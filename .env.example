# Configuration d'environnement pour KAIROS Owner Desktop
# Copier ce fichier vers .env et ajuster les valeurs selon votre environnement

# Base de données
DATABASE_URL=sqlite:///kairos_owner.db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=kairos_owner
DATABASE_USER=your_username
DATABASE_PASSWORD=your_password

# Application
APP_NAME=KAIROS Owner Desktop
APP_VERSION=1.0.0
DEBUG_MODE=False

# Sécurité
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# UI
THEME=light
LANGUAGE=fr